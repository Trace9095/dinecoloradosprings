# ============================================================
# Dine Colorado Springs — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# DATABASE (Neon Postgres — required)
# Get from: https://console.neon.tech → your project → Connection string
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ------------------------------------------------------------
# STRIPE (required for paid listing checkout)
# Get from: https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...

# Create two recurring prices in Stripe Dashboard → Products:
#   Premium:  $99/mo  → copy the price ID (price_...)
#   Sponsored: $199/mo → copy the price ID (price_...)
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_SPONSORED_PRICE_ID=price_...

# Webhook secret — get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Required events: checkout.session.completed, customer.subscription.created,
#                  customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------
# RESEND (optional — email notifications to CEO@epicai.ai)
# Get from: https://resend.com/api-keys
# Emails are skipped gracefully if this is not set.
# ------------------------------------------------------------
RESEND_API_KEY=re_...

# ------------------------------------------------------------
# JWT AUTH (admin dashboard)
# Use a long random string (openssl rand -base64 32)
# Falls back to a dev-only secret if not set — set this in production.
# ------------------------------------------------------------
JWT_SECRET=your-secret-here

# Admin email for login (defaults to CEO@epicai.ai)
ADMIN_EMAIL=CEO@epicai.ai

# ------------------------------------------------------------
# APP URL (used for Stripe success/cancel redirect URLs)
# No trailing slash.
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://dinecoloradosprings.com

# Google Analytics 4 — add your Measurement ID from analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads conversion tracking (optional)
NEXT_PUBLIC_GADS_ID=
